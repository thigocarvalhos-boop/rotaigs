// prisma/schema.prisma

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  DIRETORIA
  COORDENACAO
  ELABORADOR
  DOCUMENTAL
  FINANCEIRO
  MONITORAMENTO
  LEITURA
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(LEITURA)
  projects  Project[] @relation("ProjectResponsible")
  auditLogs AuditLog[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id              String   @id @default(uuid())
  nome            String
  edital          String
  financiador     String
  area            String
  valor           Float
  status          String
  prazo           DateTime
  responsavelId   String
  responsavel     User     @relation("ProjectResponsible", fields: [responsavelId], references: [id])
  probabilidade   Int
  risco           String
  aderencia       Int
  territorio      String
  publico         String
  competitividade String
  proximoPasso    String
  ptScore         Int
  
  metas           Meta[]
  etapas          Etapa[]
  expenses        Expense[]
  docs            Document[]
  compliance      ComplianceCheck[]
  alerts          Alert[]
  auditLogs       AuditLog[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Meta {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  descricao String
  indicador String
  meta      Float
  alcancado Float
  unidade   String
  budget    Float    @default(0)
}

model Etapa {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  nome      String
  inicio    DateTime
  fim       DateTime
  status    String
  peso      Float
}

model Expense {
  id          String   @id @default(uuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  descricao   String
  valor       Float
  data        DateTime
  categoria   String
  status      String
  justificativa String?
  vincMetaId  String
  vincEtapaId String
  cotacoes    Cotacao[]
}

model Cotacao {
  id          String   @id @default(uuid())
  expenseId   String
  expense     Expense  @relation(fields: [expenseId], references: [id])
  fornecedor  String
  valor       Float
  data        DateTime
  vencedora   Boolean
  docUrl      String?
}

model Document {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  nome      String
  status    String
  validade  DateTime?
  url       String?
  fileType  String?  // PDF, DOC, DOCX, XLS, XLSX, IMG, OTHER
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ComplianceCheck {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  item      String
  status    String
  data      DateTime @default(now())
}

model Alert {
  id        String   @id @default(uuid())
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])
  titulo    String
  mensagem  String
  nivel     String   // N1, N2, N3, N4
  status    String   // PENDENTE, RESOLVIDO
  tipo      String   // DOCUMENTO, ORCAMENTO, CRONOGRAMA, GERAL
  prazo     DateTime? // deadline date for calendar display
  lido      Boolean  @default(false)
  lidoEm    DateTime?
  lidoPor   String?
  resolucao String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  projectId  String?
  project    Project? @relation(fields: [projectId], references: [id])
  acao       String
  entidade   String   // Project, Expense, Document, etc.
  entidadeId String?
  antes      String?  // JSON string of data before change
  depois     String?  // JSON string of data after change
  data       DateTime @default(now())
}

model LessonLearned {
  id        String   @id @default(uuid())
  projeto   String
  licao     String
  categoria String?
  autor     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
