# Banco de dados — OBRIGATÓRIO
DATABASE_URL="postgresql://user:password@localhost:5432/rota_db?schema=public"

# Autenticação — OBRIGATÓRIOS, sem fallback
# Gere valores únicos com: openssl rand -base64 32
JWT_SECRET="gere-com-openssl-rand-base64-32"
JWT_REFRESH_SECRET="gere-com-openssl-rand-base64-32-diferente-do-anterior"

# Seed de admin — OBRIGATÓRIO para criação de usuário admin inicial
# Use uma senha forte e troque após o primeiro login
ADMIN_DEFAULT_PASSWORD="troque-esta-senha-antes-de-usar"

# Seed secret — OBRIGATÓRIO para proteger o endpoint de seed
# Gere com: openssl rand -base64 32
SEED_SECRET="gere-com-openssl-rand-base64-32-para-seed"

# Ambiente
NODE_ENV="development"
PORT=3000

# IA (opcional — usado apenas no servidor)
GEMINI_API_KEY=""
